generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  role     Role    @default(CUSTOMER)
}

model Wisata {
  id          Int    @id @default(autoincrement())
  nama        String
  deskripsi   String
  harga       Int
  lokasi      String
}

model Review {
  id        Int @id @default(autoincrement())
  userId    Int
  wisataId  Int
  rating    Int
  komentar  String
}
