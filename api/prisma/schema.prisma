datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Wisata {
  id          Int       @id @default(autoincrement())
  nama        String
  deskripsi   String
  lokasi      String
  latitude    Float?
  longitude   Float?
  jamBuka     String?
  hargaTiket  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  galeri      Galeri[]
  reviews     Review[]
  bookings    Booking[]
}

model Galeri {
  id        Int      @id @default(autoincrement())
  wisataId  Int
  url       String
  caption   String?
  createdAt DateTime @default(now())

  wisata    Wisata   @relation(fields: [wisataId], references: [id], onDelete: Cascade)
}

model Review {
  id         Int      @id @default(autoincrement())
  wisataId   Int
  nama       String
  rating     Int
  komentar   String
  createdAt  DateTime @default(now())

  wisata     Wisata   @relation(fields: [wisataId], references: [id], onDelete: Cascade)
}

model Booking {
  id         Int      @id @default(autoincrement())
  wisataId   Int
  nama       String
  noHp       String
  jumlahTiket Int
  totalBayar Int
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  wisata     Wisata   @relation(fields: [wisataId], references: [id], onDelete: Cascade)
}
