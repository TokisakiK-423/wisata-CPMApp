
model Booking {
  id        Int     @id @default(autoincrement())

  wisataId  Int
  wisata    Wisata  @relation(fields: [wisataId], references: [id])

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])
}

model Wisata {
  id          Int       @id @default(autoincrement())
  nama        String
  lokasi      String
  deskripsi   String
  alamat      String
  jamBuka     String
  hargaTiket  Int
  status      Boolean   @default(true) // 🔥 true = aktif, false = nonaktif

  galeri      Galeri[]
  bookings    Booking[]
}
