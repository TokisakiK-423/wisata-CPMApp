generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("admins")
}

model Customer {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  nama      String
  email     String?
  telp      String?
  createdAt DateTime  @default(now())

  bookings  Booking[]
  reviews   Review[]

  @@map("customers")
}

model Wisata {
  id         Int       @id @default(autoincrement())
  nama       String
  lokasi     String
  deskripsi  String
  alamat     String
  jamBuka    String
  hargaTiket Int?
  status     Boolean   @default(true) // true = aktif
  telepon    String?

  galeri     Galeri[]
  reviews    Review[]
  bookings   Booking[]

  @@map("wisatas")
}

model Galeri {
  id       Int     @id @default(autoincrement())
  wisataId Int
  url      String
  caption  String?

  wisata   Wisata  @relation(fields: [wisataId], references: [id], onDelete: Cascade)

  @@map("galeris")
}

model Review {
  id         Int      @id @default(autoincrement())
  wisataId   Int
  customerId Int?
  nama       String
  rating     Int
  komentar   String?
  image      String?   // 🔥 WAJIB ADA INI
  createdAt  DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  wisata   Wisata    @relation(fields: [wisataId], references: [id])
}

model Booking {
  id          Int      @id @default(autoincrement())
  wisataId    Int
  customerId  Int?

  nama        String
  noHp        String
  jumlahTiket Int
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  wisata      Wisata   @relation(fields: [wisataId], references: [id])
  customer    Customer? @relation(fields: [customerId], references: [id])

  @@map("bookings")
}
